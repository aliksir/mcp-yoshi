{
  "logDir": "~/.mcp-yoshi/logs",
  "logLevel": "info",
  "stash": {
    "enabled": true,
    "threshold": 50000,
    "dir": "~/.mcp-yoshi/stash",
    "retention_days": 30,
    "max_size": 5242880
  },
  "checks": {
    "outbound": {
      "apiKeys": true,
      "privateKeys": true,
      "highEntropy": true,
      "envValues": true,
      "pii": true,
      "largePayload": true,
      "pathTraversal": true
    },
    "inbound": {
      "promptInjection": true,
      "shellCommands": true,
      "suspiciousUrls": true,
      "scriptInjection": true,
      "toolTampering": true,
      "asciiSmuggling": true,
      "base64Payload": true,
      "responseSizeLimit": true,
      "hiddenFields": true,
      "elicitationAbuse": true,
      "samplingInjection": true,
      "logToLeak": true,
      "conversationMarker": true,
      "credentialsInResponse": true,
      "parameterOverride": true,
      "pathTraversal": true,
      "queryInjectionBlock": true,
      "queryInjectionWarn": true,
      "sandboxEscape": true,
      "headerSpoofing": true,
      "browserLaunchRCE": true
    }
  },
  "allowlist": [],
  "servers": {
    "*": { "enabled": true }
  },
  "severity": {
    "WARN": ["highEntropy", "pii", "suspiciousUrls", "base64Payload", "responseSizeLimit", "hiddenFields", "largePayload", "conversationMarker", "logToLeak", "headerSpoofing", "queryInjectionWarn"],
    "BLOCK": ["apiKeys", "privateKeys", "promptInjection", "shellCommands", "scriptInjection", "toolTampering", "envValues", "asciiSmuggling", "elicitationAbuse", "pathTraversal", "samplingInjection", "credentialsInResponse", "parameterOverride", "queryInjectionBlock", "sandboxEscape", "browserLaunchRCE"]
  }
}
