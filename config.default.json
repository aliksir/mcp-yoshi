{
  "logDir": "~/.mcp-yoshi/logs",
  "logLevel": "info",
  "checks": {
    "outbound": {
      "apiKeys": true,
      "privateKeys": true,
      "highEntropy": true,
      "envValues": true,
      "pii": true,
      "largePayload": true,
      "pathTraversal": true
    },
    "inbound": {
      "promptInjection": true,
      "shellCommands": true,
      "suspiciousUrls": true,
      "scriptInjection": true,
      "toolTampering": true,
      "asciiSmuggling": true,
      "base64Payload": true,
      "responseSizeLimit": true,
      "hiddenFields": true,
      "elicitationAbuse": true,
      "samplingInjection": true,
      "logToLeak": true,
      "conversationMarker": true
    }
  },
  "allowlist": [],
  "servers": {
    "*": { "enabled": true }
  },
  "severity": {
    "WARN": ["highEntropy", "pii", "suspiciousUrls", "base64Payload", "responseSizeLimit", "hiddenFields", "largePayload", "conversationMarker", "logToLeak"],
    "BLOCK": ["apiKeys", "privateKeys", "promptInjection", "shellCommands", "scriptInjection", "toolTampering", "envValues", "asciiSmuggling", "elicitationAbuse", "pathTraversal", "samplingInjection"]
  }
}
