{
  "logDir": "~/.mcp-yoshi/logs",
  "logLevel": "info",
  "checks": {
    "outbound": {
      "apiKeys": true,
      "privateKeys": true,
      "highEntropy": true,
      "envValues": true,
      "pii": true
    },
    "inbound": {
      "promptInjection": true,
      "shellCommands": true,
      "suspiciousUrls": true,
      "scriptInjection": true,
      "toolTampering": true,
      "asciiSmuggling": true,
      "base64Payload": true
    }
  },
  "allowlist": [],
  "servers": {
    "*": { "enabled": true }
  },
  "severity": {
    "WARN": ["highEntropy", "pii", "suspiciousUrls", "base64Payload"],
    "BLOCK": ["apiKeys", "privateKeys", "promptInjection", "shellCommands", "scriptInjection", "toolTampering", "envValues", "asciiSmuggling"]
  }
}
